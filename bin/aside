#!/usr/bin/env bash
set -euo pipefail

OPENCODE_BIN="${HOME}/.opencode/bin/opencode"
ASIDE_PORT=4096
BUNDLE_ID="com.ericclemmons.aside.app"

# --- Server Discovery ---

discover_server() {
  local target
  target=$(defaults read "$BUNDLE_ID" selectedServerTarget 2>/dev/null || echo "aside")

  case "$target" in
    desktop)
      discover_desktop
      ;;
    *)
      # Default to aside server
      SERVER_HOST="127.0.0.1"
      SERVER_PORT="$ASIDE_PORT"
      SERVER_URL="http://127.0.0.1:${ASIDE_PORT}"
      SERVER_AUTH=""
      SERVER_TARGET="aside"

      # Verify aside server is running
      if ! curl -sf "${SERVER_URL}/session" >/dev/null 2>&1; then
        json_error "Aside server not running on port ${ASIDE_PORT}. Start Aside.app or: defaults write ${BUNDLE_ID} selectedServerTarget desktop"
        exit 1
      fi
      ;;
  esac
}

discover_desktop() {
  local ps_output line port host username password
  ps_output=$(ps ewwA -o pid,command 2>/dev/null) || {
    json_error "failed to list processes"
    exit 1
  }

  while IFS= read -r line; do
    # Match OpenCode Desktop's bundled CLI serve process
    [[ "$line" == *"OpenCode.app"* && "$line" == *"opencode-cli"* && "$line" == *"serve"* ]] || continue
    [[ "$line" == *"grep"* ]] && continue

    # Extract --port
    if [[ "$line" =~ --port[=\ ]([0-9]+) ]]; then
      port="${BASH_REMATCH[1]}"
    else
      continue
    fi

    # Extract --hostname (default 127.0.0.1)
    if [[ "$line" =~ --hostname[=\ ]([^\ ]+) ]]; then
      host="${BASH_REMATCH[1]}"
    else
      host="127.0.0.1"
    fi

    # Extract credentials from env vars in ps output
    if [[ "$line" =~ OPENCODE_SERVER_USERNAME=([^\ ]+) ]]; then
      username="${BASH_REMATCH[1]}"
    else
      username="opencode"
    fi

    if [[ "$line" =~ OPENCODE_SERVER_PASSWORD=([^\ ]+) ]]; then
      password="${BASH_REMATCH[1]}"
    else
      continue  # password required
    fi

    SERVER_HOST="$host"
    SERVER_PORT="$port"
    SERVER_URL="http://${host}:${port}"
    SERVER_AUTH="${username}:${password}"
    SERVER_TARGET="desktop"

    export OPENCODE_SERVER_USERNAME="$username"
    export OPENCODE_SERVER_PASSWORD="$password"
    return 0
  done <<< "$ps_output"

  json_error "OpenCode Desktop server not found. Start OpenCode Desktop or: defaults write ${BUNDLE_ID} selectedServerTarget aside"
  exit 1
}

# --- Helpers ---

json_error() {
  jq -n --arg error "$1" '{error: $error}' >&2
}

# Get the most recent session's directory from the server
recent_dir() {
  local curl_args=(-sf "${SERVER_URL}/session")
  if [[ -n "$SERVER_AUTH" ]]; then
    curl_args+=(-u "$SERVER_AUTH")
  fi

  curl "${curl_args[@]}" 2>/dev/null \
    | jq -r '[.[] | select(.directory != "/" and .directory != "" and .directory != "~") | {dir: .directory, updated: .time.updated}] | sort_by(.updated) | reverse | .[0].dir // empty' 2>/dev/null
}

cmd_help() {
  echo "usage: aside [--session id] <command> [options]"
  echo ""
  echo "commands:"
  echo "  prompt [-d dir] [-f file] \"text\"   dispatch prompt (new or to --session)"
  echo "  sessions                            list sessions (JSON)"
  echo "  server                              show active server"
  echo "  attach                              open opencode TUI"
}

# --- Commands ---

cmd_prompt() {
  local dir="" prompt="" files=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -d|--dir)     dir="$2"; shift 2 ;;
      -f|--file)    files+=("$2"); shift 2 ;;
      -*)           json_error "unknown flag: $1"; exit 1 ;;
      *)            prompt="$1"; shift ;;
    esac
  done

  # Read prompt from stdin if not provided as argument
  if [[ -z "$prompt" ]] && ! [ -t 0 ]; then
    prompt=$(cat)
  fi

  if [[ -z "$prompt" ]]; then
    json_error "no prompt provided. usage: aside [--session id] prompt [-d dir] [-f file ...] \"text\""
    exit 1
  fi

  discover_server

  # Build opencode command
  local global_flags=("--attach" "$SERVER_URL")

  if [[ -n "$SESSION" ]]; then
    global_flags+=("--session" "$SESSION")
  fi

  # Default to most recent session's workspace dir
  if [[ -z "$dir" ]]; then
    dir=$(recent_dir)
  fi
  if [[ -n "$dir" ]]; then
    global_flags+=("--dir" "$dir")
  fi

  local run_flags=()
  for f in "${files[@]}"; do
    run_flags+=("--file=${f}")
  done

  # Augment PATH
  export PATH="${HOME}/.opencode/bin:/opt/homebrew/bin:/usr/local/bin:${PATH}"

  echo "$prompt" | "$OPENCODE_BIN" "${global_flags[@]}" run "${run_flags[@]}"
}

cmd_sessions() {
  discover_server

  local curl_args=(-sf "${SERVER_URL}/session")
  if [[ -n "$SERVER_AUTH" ]]; then
    curl_args+=(-u "$SERVER_AUTH")
  fi

  curl "${curl_args[@]}" | jq .
}

cmd_server() {
  discover_server

  local auth="false"
  if [[ -n "$SERVER_AUTH" ]]; then
    auth="true"
  fi

  jq -n \
    --arg target "$SERVER_TARGET" \
    --arg url "$SERVER_URL" \
    --argjson auth "$auth" \
    '{target: $target, url: $url, auth: $auth}'
}

cmd_attach() {
  discover_server

  export PATH="${HOME}/.opencode/bin:/opt/homebrew/bin:/usr/local/bin:${PATH}"

  local args=("$SERVER_URL" "--continue")
  local dir
  dir=$(recent_dir)
  if [[ -n "$dir" ]]; then
    args+=("--dir" "$dir")
  fi
  if [[ -n "${1:-}" ]]; then
    args+=("$@")
  fi

  exec "$OPENCODE_BIN" attach "${args[@]}"
}

# --- Main ---

# Parse global flags before subcommand
SESSION=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    -s|--session)  SESSION="$2"; shift 2 ;;
    --session=*)   SESSION="${1#--session=}"; shift ;;
    -*)
      # Check if it's help before treating as unknown
      if [[ "$1" == "-h" || "$1" == "--help" ]]; then
        cmd_help; exit 0
      fi
      json_error "unknown flag: $1"
      cmd_help >&2
      exit 1
      ;;
    *)  break ;;
  esac
done

case "${1:-}" in
  prompt)   shift; cmd_prompt "$@" ;;
  run)      shift; cmd_prompt "$@" ;;  # back-compat alias
  sessions) cmd_sessions ;;
  server)   cmd_server ;;
  attach)   shift; cmd_attach "$@" ;;
  "")
    cmd_help
    exit 1
    ;;
  *)
    json_error "unknown command: $1"
    cmd_help >&2
    exit 1
    ;;
esac
