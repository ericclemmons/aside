{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aside",
  "version": "0.1.0",
  "identifier": "com.aside.app",
  "build": {
    "beforeDevCommand": "pnpm vite",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist",
    "features": ["parakeet"]
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "overlay",
        "title": "Aside",
        "width": 420,
        "height": 340,
        "center": true,
        "resizable": false,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": false,
        "skipTaskbar": true,
        "visible": false,
        "shadow": true,
        "theme": "Dark",
        "windowEffects": {
          "effects": ["hudWindow"],
          "state": "active",
          "radius": 16.0
        }
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "Entitlements.plist",
      "hardenedRuntime": true,
      "signingIdentity": "-",
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null
    }
  }
}
